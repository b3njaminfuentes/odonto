generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Patient {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?       @unique @db.Uuid // Supabase auth.users ID
  patientCode  String        @unique @db.VarChar(20)
  fullName     String        @db.VarChar(255)
  email        String?       @db.VarChar(255)
  phone        String?       @db.VarChar(50)
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  
  appointments Appointment[]
  cases        Case[]
  payments     Payment[]

  @@map("patients")
}

model Appointment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId       String?   @db.Uuid
  treatmentType   String?   @db.VarChar(100)
  appointmentDate DateTime  @db.Date
  startTime       DateTime  @db.Time(6)
  endTime         DateTime  @db.Time(6)
  status          String?   @default("reservado") @db.VarChar(50)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)

  patient Patient? @relation(fields: [patientId], references: [id])
  payments Payment[]

  @@map("appointments")
}

model Case {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String?   @db.Uuid
  title         String    @db.VarChar(255)
  description   String?
  treatmentType String?   @db.VarChar(100)
  createdBy     String?   @db.Uuid // Doctor ID (Supabase auth.users ID)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)

  patient Patient? @relation(fields: [patientId], references: [id])
  media   CaseMedia[]

  @@map("cases")
}

model CaseMedia {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId     String?  @db.Uuid
  mediaType  String?  @db.VarChar(50)
  url        String
  caption    String?
  visibility String?  @default("solo_paciente_dueno") @db.VarChar(50)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  case Case? @relation(fields: [caseId], references: [id])

  @@map("case_media")
}

model Payment {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String?   @db.Uuid
  appointmentId String?   @db.Uuid
  amount        Decimal   @db.Decimal(10, 2)
  currency      String?   @default("BOB") @db.VarChar(10)
  status        String?   @default("pendiente") @db.VarChar(50)
  method        String?   @db.VarChar(50)
  paidAt        DateTime? @db.Timestamptz(6)
  qrReference   String?   @db.VarChar(255)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)

  patient     Patient?     @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("payments")
}
