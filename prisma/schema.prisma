generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum PatientStatus {
  ACTIVE
  IN_TREATMENT
  CONTROL
  INACTIVE
  ARCHIVED
}

enum AppointmentStatus {
  DISPONIBLE
  PENDIENTE
  CONFIRMADO
  OCUPADO
  CANCELADO
}

enum TreatmentStatus {
  ACTIVO
  COMPLETADO
  PAUSADO
  CANCELADO
}

enum PaymentStatus {
  PENDIENTE
  COMPLETADO
  FALLIDO
  REEMBOLSADO
  CANCELADO
}

model Profile {
  id        String   @id @db.Uuid // Referencia a auth.users.id
  role      String   @default("patient") // 'admin' | 'patient'
  email     String   @unique
  createdAt DateTime @default(now())

  patient Patient?

  @@index([email])
}

model Patient {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId        String?       @unique @db.Uuid
  patientCode      String        @unique
  dni              String?       @unique
  passport         String?
  firstName        String
  lastName         String
  dob              DateTime      @db.Date
  email            String?       @unique
  phone            String?
  emergencyContactName String?
  emergencyContactPhone String?
  referralSource   String? // Cómo nos conoció: Facebook, Instagram, TikTok, Google Maps, Recomendado, Otro
  address          String?
  status           PatientStatus @default(ACTIVE)
  profilePhotoId   String?       @db.Uuid // Opcional, referencia a CaseMedia o un bucket ID
  accessCode       String?       @unique // Código de acceso al portal (lo entrega la dra por WhatsApp)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  profile      Profile?         @relation(fields: [profileId], references: [id])
  appointments Appointment[]
  treatments   Treatment[]
  history      ClinicalHistory?
  odontogram   Odontogram?
  diagnoses    Diagnosis[]
  payments     Payment[]
  events       TimelineEvent[]
  media        CaseMedia[]

  @@index([dni])
  @@index([phone])
  @@index([status])
}

model Diagnosis {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String   @db.Uuid
  description String
  toothNumber String? // notación FDI, opcional
  diagnosedAt DateTime @default(now())
  diagnosedBy String   @db.Uuid
  treatmentId String?  @db.Uuid

  patient   Patient    @relation(fields: [patientId], references: [id])
  treatment Treatment? @relation(fields: [treatmentId], references: [id])

  @@index([patientId])
  @@index([treatmentId])
}

model Odontogram {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String   @unique @db.Uuid
  chart     Json
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
}

model ClinicalHistory {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId        String   @unique @db.Uuid
  medicalHistory   Json?
  dentalBackground String?
  observations     String?
  updatedAt        DateTime @updatedAt

  patient  Patient                  @relation(fields: [patientId], references: [id])
  versions ClinicalHistoryVersion[]
}

model ClinicalHistoryVersion {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicalHistoryId String   @db.Uuid
  medicalHistory    Json?
  dentalBackground  String?
  observations      String?
  changedBy         String   @db.Uuid
  createdAt         DateTime @default(now())

  clinicalHistory ClinicalHistory @relation(fields: [clinicalHistoryId], references: [id])

  @@index([clinicalHistoryId])
}

model Treatment {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId        String          @db.Uuid
  name             String
  description      String?
  toothNumber      String?
  startDate        DateTime        @db.Date
  estimatedEndDate DateTime?       @db.Date
  status           TreatmentStatus @default(ACTIVO)
  budget           Decimal?        @db.Decimal(10, 2)
  finalCost        Decimal?        @db.Decimal(10, 2)
  createdAt        DateTime        @default(now())

  patient   Patient     @relation(fields: [patientId], references: [id])
  media     CaseMedia[]
  diagnoses Diagnosis[]
  payments  Payment[]

  @@index([patientId])
  @@index([status])
}

model CaseMedia {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String   @db.Uuid
  treatmentId String?  @db.Uuid
  bucket      String // 'patients-profile', 'cases-images', 'cases-videos', 'radiographs', 'documents'
  fileUrl     String
  category    String?
  description String?
  mimeType    String?
  size        Int?
  uploadedBy  String   @db.Uuid
  visibleToPatient Boolean @default(false)
  createdAt   DateTime @default(now())

  patient   Patient    @relation(fields: [patientId], references: [id])
  treatment Treatment? @relation(fields: [treatmentId], references: [id])

  @@index([patientId])
  @@index([treatmentId])
}

model Appointment {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String?           @db.Uuid
  treatmentType String?
  startsAt      DateTime
  endsAt        DateTime
  status        AppointmentStatus @default(DISPONIBLE)
  notes         String?
  createdAt     DateTime          @default(now())

  patient Patient? @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([startsAt])
  @@index([status])
}

model Payment {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String        @db.Uuid
  treatmentId String?       @db.Uuid
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("BOB")
  status      PaymentStatus @default(PENDIENTE)
  method      String?
  notes       String?
  receiptUrl  String?
  date        DateTime      @default(now())

  patient   Patient    @relation(fields: [patientId], references: [id])
  treatment Treatment? @relation(fields: [treatmentId], references: [id])

  @@index([patientId])
  @@index([treatmentId])
}

model TimelineEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String   @db.Uuid
  eventType   String
  title       String
  description String?
  metadata    Json?
  severity    String?  @default("info") // info, warning, critical
  createdBy   String?  @db.Uuid
  createdAt   DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([createdAt])
}

model ClinicSettings {
  id                       String   @id @default("main")
  clinicName               String   @default("Clínica Odontológica Villarroel")
  phone                    String?
  address                  String?
  currency                 String   @default("BOB")
  doctorName               String?  @default("Dra. Villarroel")
  specialty                String?
  pendingAppointmentsAlert Boolean  @default(true)
  updatedAt                DateTime @default(now()) @updatedAt
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  action    String
  entity    String
  entityId  String
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
}
